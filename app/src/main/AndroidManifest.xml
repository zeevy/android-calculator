<?xml version="1.0" encoding="utf-8"?>
<!--
  Calculator AndroidManifest.

  Notes:
    - The app is still fully offline (no INTERNET permission).
    - Floating-calculator feature uses three permissions:
        * SYSTEM_ALERT_WINDOW    - draw the floating window over apps.
        * FOREGROUND_SERVICE     - host the overlay in a fg service so
                                   it survives once the user leaves the app.
        * FOREGROUND_SERVICE_SPECIAL_USE - required for fg services on
                                   API 34+; SPECIAL_USE is the catch-all
                                   for "ongoing UI the user opted into".
        * POST_NOTIFICATIONS     - lets the fg service show its required
                                   ongoing notification on API 33+.
      Users opt in via the Float tile in the menu; SYSTEM_ALERT_WINDOW
      is granted through the system Settings flow we open on demand.
    - Auto Backup is enabled (backupAgent rules in backup_rules.xml) so user
      preferences and history survive a reinstall.
    - The activity declares a Material 3 SplashScreen theme; the theme then
      transitions to the app theme inside MainActivity once Compose attaches.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".CalculatorApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Calculator.Starting"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Calculator.Starting"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Launcher long-press shortcuts are published dynamically by
                 RecentToolsRegistry (see CalculatorApplication.onCreate);
                 no static shortcuts.xml because hardcoded targetPackage
                 doesn't match the debug build's `.debug` suffix. -->
        </activity>

        <!-- Phase 10: Glance home-screen widget. -->
        <receiver
            android:name=".core.widget.QuickCalcWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_calc_widget_info" />
        </receiver>

        <!-- Phase 10: Quick Settings tile to open the basic calculator. -->
        <service
            android:name=".core.widget.QuickCalculatorTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_calculator"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Floating calculator overlay (hosted by a foreground service so
             it survives leaving the app). SPECIAL_USE is the foreground
             service type required on API 34+ for ongoing UI surfaces. -->
        <service
            android:name=".feature.floating.FloatingCalculatorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating_calculator" />
        </service>

        <!-- Headless trampoline for the "Floating calculator" launcher
             shortcut. Translucent theme + immediate finish() means no
             splash flash before the overlay (or system permission page)
             appears. -->
        <activity
            android:name=".feature.floating.FloatingShortcutActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:noHistory="true" />

    </application>

</manifest>
