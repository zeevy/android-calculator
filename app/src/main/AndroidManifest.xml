<?xml version="1.0" encoding="utf-8"?>
<!--
  Calculator AndroidManifest.

  Notes:
    - INTERNET is the only declared permission; it is used exclusively by the
      currency-rate converter. Every other feature works fully offline.
    - There are no runtime-permission requests; this manifest entry alone is sufficient.
    - Auto Backup is enabled (backupAgent rules in backup_rules.xml) so user
      preferences and history survive a reinstall.
    - The activity declares a Material 3 SplashScreen theme; the theme then
      transitions to the app theme inside MainActivity once Compose attaches.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".CalculatorApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Calculator.Starting"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Calculator.Starting"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Static launcher shortcuts shown on long-press of the app icon. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Phase 10: Glance home-screen widget. -->
        <receiver
            android:name=".core.widget.QuickCalcWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_calc_widget_info" />
        </receiver>

        <!-- Phase 10: Quick Settings tile to open the basic calculator. -->
        <service
            android:name=".core.widget.QuickCalculatorTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_calculator"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>
