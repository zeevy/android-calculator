<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact floating calculator overlay.

  XML view (not Compose) because Compose's runtime expects an Activity /
  Lifecycle owner and the overlay is hosted by a Service. A handful of
  TextView / Button rows costs less complexity than wiring a stand-alone
  ComposeView with manual recomposers and lifecycle plumbing.

  Layout uses horizontal LinearLayouts (one per keypad row). Width,
  height, weight and margin are set inline on each Button rather than
  from a style because Android often ignores layout_* attributes set
  via styles (the child picks them up but the parent's layout pass
  doesn't), which left the earlier version one-column wide.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_bg"
    android:padding="12dp"
    android:elevation="8dp">

    <!-- Header: title (also the drag handle) + close button. -->
    <LinearLayout
        android:id="@+id/floating_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/floating_header"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/floating_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Display. Single line, right-aligned, large numeric font. -->
    <TextView
        android:id="@+id/floating_display"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical|end"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="start" />

    <!-- Row 1: C  ⌫  %  ÷ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/floating_C" android:text="C"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_modifier"
            android:textColor="#000000"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_back" android:text="⌫"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_modifier"
            android:textColor="#000000"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_pct" android:text="%"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_modifier"
            android:textColor="#000000"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_div" android:text="÷"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>

    <!-- Row 2: 7 8 9 × -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/floating_7" android:text="7"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_8" android:text="8"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_9" android:text="9"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_mul" android:text="×"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>

    <!-- Row 3: 4 5 6 - -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/floating_4" android:text="4"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_5" android:text="5"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_6" android:text="6"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_sub" android:text="-"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>

    <!-- Row 4: 1 2 3 + -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/floating_1" android:text="1"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_2" android:text="2"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_3" android:text="3"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_add" android:text="+"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>

    <!-- Row 5: 0 (wide, weight=2) . = -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/floating_0" android:text="0"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="2"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_dot" android:text="."
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_eq" android:text="="
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>
</LinearLayout>
