<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact floating calculator overlay.

  XML view (not Compose) because Compose's runtime expects an Activity /
  Lifecycle owner and the overlay is hosted by a Service.

  Layout mirrors the in-app keypad's tall-`+` pattern:
    Row 1: [ ⌫ ][ % ][ - ][ ÷ ]     (⌫ long-press clears - no separate C key)
    Row 2: [ 7 ][ 8 ][ 9 ][ × ]
    Row 3: [ 4 ][ 5 ][ 6 ][   ]     tall + spans rows 3-4 in the
    Row 4: [ 1 ][ 2 ][ 3 ][ + ]     fourth column
    Row 5: [   0   ][ . ][ = ]

  Width / height / weight / margin live inline on each Button because
  Android often ignores layout_* attributes set via styles in nested-
  LinearLayout setups, which previously collapsed columns to wrap_content.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="260dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_bg"
    android:padding="12dp"
    android:elevation="8dp">

    <!-- Header: title (also the drag handle) + close button. -->
    <LinearLayout
        android:id="@+id/floating_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/floating_header"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/floating_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Display. Single line, right-aligned, large numeric font. -->
    <TextView
        android:id="@+id/floating_display"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical|end"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="start" />

    <!-- Row 1: ⌫ (long-press = clear), %, -, ÷ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/floating_back" android:text="⌫"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_modifier"
            android:textColor="#000000"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_pct" android:text="%"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_modifier"
            android:textColor="#000000"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_sub" android:text="-"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_div" android:text="÷"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>

    <!-- Row 2: 7 8 9 × -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/floating_7" android:text="7"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_8" android:text="8"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_9" android:text="9"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_mul" android:text="×"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>

    <!-- Rows 3-4 grouped: digits 4-6 and 1-3 on the left (a vertical
         column of two rows), double-height + on the right. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/floating_4" android:text="4"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
                    style="@style/FloatingKeyBase" />
                <Button android:id="@+id/floating_5" android:text="5"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
                    style="@style/FloatingKeyBase" />
                <Button android:id="@+id/floating_6" android:text="6"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
                    style="@style/FloatingKeyBase" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/floating_1" android:text="1"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
                    style="@style/FloatingKeyBase" />
                <Button android:id="@+id/floating_2" android:text="2"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
                    style="@style/FloatingKeyBase" />
                <Button android:id="@+id/floating_3" android:text="3"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
                    style="@style/FloatingKeyBase" />
            </LinearLayout>
        </LinearLayout>

        <!-- Double-height + button. Height = 2*key + the gap between
             rows (6dp of margin), giving a column that matches the
             left block's two-row total. -->
        <Button android:id="@+id/floating_add" android:text="+"
            android:layout_width="0dp" android:layout_height="94dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>

    <!-- Row 5: 0 (weight=2) . = -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/floating_0" android:text="0"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="2"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_dot" android:text="."
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_digit"
            style="@style/FloatingKeyBase" />
        <Button android:id="@+id/floating_eq" android:text="="
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_margin="3dp" android:background="@drawable/floating_key_op"
            android:textStyle="bold"
            style="@style/FloatingKeyBase" />
    </LinearLayout>
</LinearLayout>
