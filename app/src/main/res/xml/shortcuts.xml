<?xml version="1.0" encoding="utf-8"?>
<!--
  Static launcher shortcuts.

  Only "Floating calculator" is static - it's the one shortcut the user
  should see even before they've ever opened a tool. The rest of the
  long-press menu is filled by dynamic shortcuts pushed from
  [RecentToolsRegistry] as the user navigates between tools.

  android:targetPackage is intentionally omitted: the build flavour
  adds a `.debug` suffix to the applicationId, and hardcoding
  `com.calculator` here made the launcher show "App not installed" on
  debug builds. Without it, the system resolves to the package that
  declared the shortcut - works for both flavours.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="floating_calculator"
        android:icon="@mipmap/ic_launcher_round"
        android:shortcutShortLabel="@string/shortcut_floating_short"
        android:shortcutLongLabel="@string/shortcut_floating_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetClass="com.calculator.feature.floating.FloatingShortcutActivity" />
    </shortcut>

</shortcuts>
