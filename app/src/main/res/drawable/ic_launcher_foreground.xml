<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground.

  The mark itself - green disk + white ring + calculator body with the
  +, -, x operators + a "CA" badge - lives in the per-density PNGs
  under res/mipmap-{m,h,x,xx,xxx}dpi/ic_launcher_foreground.png.
  Master vector is at assets/logo/calculator_logo.svg.

  Using a bitmap rather than an Android Vector Drawable here because
  the design includes serif lettering ("CA") that's painful to
  represent as raw <path> commands without a font-to-path conversion
  step. The PNGs are pre-rendered from the master SVG via sips and
  ship at every launcher density up through xxxhdpi (432px).

  android:gravity="fill" stretches the bitmap to the 108-vu adaptive
  icon viewport; the PNGs are square so this preserves the design.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@mipmap/ic_launcher_foreground"
    android:gravity="fill" />
